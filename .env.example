# DataForSEO credentials — lấy tại https://dataforseo.com → Profile
DATAFORSEO_EMAIL=your_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# Đặt true để dùng sandbox (không tốn credit, data test)
DATAFORSEO_SANDBOX=false

# Đường dẫn file SQLite (mặc định: rivalscope.db trong thư mục hiện tại)
# DB_PATH=rivalscope.db
