      671 +                                                              
      672 +async function loadHistoryRecord(id) {                        
      673 +  try {                                                       
      674 +    const res = await fetch(`/api/history/${id}`);            
      675 +    if (!res.ok) return;                                      
      676 +    const data = await res.json();                            
      677 +    analysisData = { [data.domain]: data.result };            
      678 +    renderResults({ [data.domain]: data.result });            
      679 +    document.getElementById('results').scrollIntoView({ behavi
          +or: 'smooth', block: 'start' });                              
      680 +  } catch (err) {                                             
      681 +    showGlobalError('Không tải được kết quả: ' + err.message);
      682 +  }                                                           
      683 +}                                                             
      684 +                                                              
      685 +loadHistory();                                                
