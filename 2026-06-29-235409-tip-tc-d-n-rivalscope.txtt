      694 +function exportCSV() {                                        
      695 +  if (!Object.keys(analysisData).length) return;              
      696 +                                                              
      697 +  const BOM = ''; // giúp Excel đọc đúng tiếng Việt           
      698 +  const headers = ['Domain', 'Thị trường', 'Từ khoá', 'Chủ đề'
          +, 'Vị trí', 'Volume/tháng', 'Traffic ước tính', 'URL xếp hạng'
          +];                                                            
      699 +  const rows = [headers];                                     
      700 +                                                              
      701 +  const marketLabel = { vn: 'Việt Nam', us: 'US', sg: 'Singapo
          +re', au: 'Australia', gb: 'UK' };                             
      702 +  const market = marketLabel[currentDatabase] || currentDataba
          +se;                                                           
      703 +                                                              
      704 +  for (const [domain, data] of Object.entries(analysisData)) {
      705 +    if (data.error) continue;                                 
      706 +    for (const kw of (data.top_keywords || [])) {             
      707 +      rows.push([domain, market, kw.keyword, kw.topic, kw.posi
          +tion, kw.volume, kw.etv, kw.url]);                            
      708 +    }                                                         
      709 +  }                                                           
      710 +                                                              
      711 +  const csv = BOM + rows.map(r =>                             
      712 +    r.map(v => `"${String(v ?? '').replace(/"/g, '""')}"`).joi
          +n(',')                                                        
      713 +  ).join('\r\n');                                             
      714 +                                                              
      715 +  const domains = Object.keys(analysisData).join('_');        
      716 +  const date = new Date().toISOString().slice(0, 10);         
      717 +  const filename = `rivalscope_${domains}_${date}.csv`;       
      718 +                                                              
      719 +  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8
          +;' });                                                        
      720 +  const url = URL.createObjectURL(blob);                      
      721 +  const a = document.createElement('a');                      
      722 +  a.href = url; a.download = filename; a.click();             
      723 +  URL.revokeObjectURL(url);                                   
      724 +}                                                             
